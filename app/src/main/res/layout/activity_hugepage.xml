<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".ui.hugepage.HugePageActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="?attr/homeAsUpIndicator" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:id="@+id/content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_crash_warning"
                style="?attr/materialCardViewFilledStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="?attr/colorErrorContainer"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="10dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/hugepage_crash_warning"
                        android:src="@drawable/ic_bug"
                        app:tint="?attr/colorOnErrorContainer" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="@string/hugepage_crash_warning"
                        android:textAppearance="?attr/textAppearanceTitleSmall"
                        android:textColor="?attr/colorOnErrorContainer" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/hugepage_dismiss_crash"
                        android:textAppearance="?attr/textAppearanceLabelLarge"
                        android:textColor="?attr/colorPrimary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_not_installed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="?attr/colorErrorContainer"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="10dp"
                    tools:ignore="UseCompoundDrawables">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/hugepage_not_loaded"
                        android:src="@drawable/ic_package"
                        app:tint="?attr/colorOnErrorContainer" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="@string/hugepage_not_loaded"
                        android:textAppearance="?attr/textAppearanceTitleSmall"
                        android:textColor="?attr/colorOnErrorContainer" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Pool size and (below) the with-CMA total, stacked so neither is
                 cramped. Both are GiB-only inputs (ti_unit): no MB/KB/B stops.
                 The with-CMA row is enabled only while the reservoir is on. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <cn.classfun.droidvm.ui.widgets.row.TextInputRowWidget
                    android:id="@+id/input_pool_size"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hugepage_pool_size"
                    android:icon="@drawable/ic_resize"
                    android:inputType="number"
                    app:ti_max="16GiB"
                    app:ti_min="0MiB"
                    app:ti_mode="size"
                    app:ti_precision="2MiB"
                    app:ti_unit="GiB" />

                <cn.classfun.droidvm.ui.widgets.row.TextInputRowWidget
                    android:id="@+id/input_cma_size"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hugepage_cma_pool_size"
                    android:icon="@drawable/ic_resize"
                    android:inputType="number"
                    app:ti_max="24GiB"
                    app:ti_min="0MiB"
                    app:ti_mode="size"
                    app:ti_precision="2MiB"
                    app:ti_unit="GiB" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:layout_weight="1">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_save_pool_size"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/hugepage_save_pool_size"
                        app:icon="@drawable/ic_floppy" />

                    <!-- Acquire spinner with a pause glyph in the centre. Not
                         clickable itself: touches pass through to the button
                         below, whose handler interrupts the acquire. -->
                    <FrameLayout
                        android:id="@+id/progress_save_pool_size"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <ProgressBar
                            style="?android:attr/progressBarStyleSmall"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:indeterminate="true"
                            android:indeterminateTint="?attr/colorOnSecondaryContainer" />

                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_gravity="center"
                            android:contentDescription="@string/hugepage_proc_acquire_stop"
                            android:src="@drawable/ic_pause"
                            app:tint="?attr/colorOnSecondaryContainer" />
                    </FrameLayout>
                </FrameLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_module_toggle"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:layout_weight="1"
                    android:text="@string/hugepage_btn_enable"
                    app:icon="@drawable/ic_start" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:orientation="vertical">

                <cn.classfun.droidvm.ui.hugepage.SegmentedBar
                    android:id="@+id/seg_pool_bar"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_margin="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_pool_used"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tv_pool_avail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:layout_marginTop="2dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_pool_total"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tv_pool_size"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp" />

                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_view_processes"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:text="@string/hugepage_view_processes"
                app:icon="@drawable/ic_file_tree" />

            <!-- Same row style as the TextRowWidget/SwitchRowWidget rows below:
                 icon, label, then the interactive controls on the right. -->
            <LinearLayout
                android:id="@+id/row_acquire_pages"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:minHeight="72dp"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_memory" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="32dp"
                    android:layout_weight="1"
                    android:text="@string/hugepage_acquire_pages_title"
                    android:textSize="16sp" />

                <include layout="@layout/acquire_buttons" />
            </LinearLayout>

            <cn.classfun.droidvm.ui.widgets.row.SwitchRowWidget
                android:id="@+id/row_cma_enable"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/ic_memory"
                android:subtitle="@string/hugepage_enable_cma_sub"
                android:text="@string/hugepage_enable_cma" />

            <cn.classfun.droidvm.ui.widgets.row.SwitchRowWidget
                android:id="@+id/row_module_enable"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/ic_package"
                android:text="@string/hugepage_enable_module" />

            <cn.classfun.droidvm.ui.widgets.row.TextRowWidget
                android:id="@+id/row_stat_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/ic_info"
                android:text="@string/hugepage_stat_state" />

            <cn.classfun.droidvm.ui.widgets.row.TextRowWidget
                android:id="@+id/row_stat_total_served"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/ic_counter"
                android:text="@string/hugepage_stat_total_served" />

            <cn.classfun.droidvm.ui.widgets.row.TextRowWidget
                android:id="@+id/row_stat_total_refilled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/ic_refresh"
                android:text="@string/hugepage_stat_total_refilled" />

            <cn.classfun.droidvm.ui.widgets.row.TextRowWidget
                android:id="@+id/row_stat_active_vms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/ic_nav_vm"
                android:text="@string/hugepage_stat_active_vms" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
